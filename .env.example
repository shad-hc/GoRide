
#  GoRide — Environment Configuration
#  Copy this file to .env and fill in your value

# ── Server 
NODE_ENV=development
PORT=5000
API_VERSION=v1

# ── JWT Auth 
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_secret_key
JWT_REFRESH_EXPIRES_IN=30d

# ── MongoDB 
MONGO_ROOT_USER=your_admin
MONGO_ROOT_PASS=your_password
MONGO_URI=your_mongo_url

# ── Redis 
REDIS_URL=your_redis_url
REDIS_PASSWORD =your_redis_password

# ── CORS
CORS_ORIGIN=http://localhost:3000

# ── Geospatial 
# Default search radius for nearby drivers (meters)
DRIVER_SEARCH_RADIUS=5000
# Maximum driver search radius (meters)
DRIVER_MAX_RADIUS=20000

# ── Pricing ─
BASE_FARE=2.50
COST_PER_KM=1.20
COST_PER_MIN=0.25
SURGE_MULTIPLIER_MAX=3.0

# ── Ride Settings 
RIDE_REQUEST_TIMEOUT_SECONDS=30
DRIVER_ACCEPTANCE_TIMEOUT_SECONDS=60

# ── Cache TTLs (seconds)
CACHE_ROUTE_TTL=3600
CACHE_PRICING_TTL=300
CACHE_USER_TTL=600

# ── Logging ─
LOG_LEVEL=info
LOG_FILE=logs/app.log

# ── Frontend 
REACT_APP_API_URL=http://localhost:5000
REACT_APP_SOCKET_URL=http://localhost:5000
REACT_APP_MAPBOX_TOKEN=your_mapbox_public_token_here

# ── Bull Queue (Redis-backed) 
BULL_REDIS_URL=your_redis_url
